{
  "version": 2,
  "buildCommand": "npm install -g pnpm@10 && pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "vercel.mjs": {
      "runtime": "@vercel/node@4",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/vercel.mjs" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
